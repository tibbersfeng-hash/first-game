# ═══════════════════════════════════════════════════════════════
#  first-game .gitignore
#  策略：C++ 源码 + 文档 → GitHub | 二进制资产 → OSS
#  详见 tools/oss-assets/README.md
# ═══════════════════════════════════════════════════════════════

# ── IDE / Editor ──────────────────────────────────────────────
.vs/
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/

# ── Claude Code Local ─────────────────────────────────────────
.claude/settings.local.json
CLAUDE.local.md
production/session-logs/

# ── Internal Planning (not for public) ────────────────────────
expansions/
marrow/

# ── Runtime Artifacts ─────────────────────────────────────────
docs/consistency-failures.md

# ── Build Output ──────────────────────────────────────────────
build/
builds/
bin/
obj/
out/
dist/
*.exe
*.dll
*.so
*.dylib
*.app

# ── Unreal Engine 5 ──────────────────────────────────────────
Binaries/
DerivedDataCache/
Intermediate/
Saved/
*.VC.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.spv
*.cso
*.dxbc

# UE5 Plugins (large / external)
src_ue5/Plugins/McpAutomationBridge/

# ★ UE5 Content — 所有二进制资产走 OSS ★
# 包括 .uasset .umap .fbx .png 等所有 Content/ 下的文件
# 例外：Content/Python/ 下的脚本是源码，留在 git
src_ue5/Content/*
!src_ue5/Content/Python/

# ── Binary Assets (走 OSS) ───────────────────────────────────
# 图片
*.png
*.jpg
*.jpeg
*.tga
*.bmp
*.exr
*.hdr
*.psd
*.tif
*.tiff

# 3D 模型 / 动画
*.fbx
*.obj
*.gltf
*.glb
*.blend
*.max

# 音频
*.wav
*.mp3
*.ogg
*.flac

# 视频
*.mp4
*.mov
*.webm
*.avi

# FBX 材质子目录
*.fbm/

# ── Archives ─────────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z
*.cab
*.msi
*.msix
*.msm
*.msp

# ── Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# ── Temp / Cache ─────────────────────────────────────────────
*.tmp
*.temp
*.cache
*.log
*.bak
__pycache__/
*.pyc
node_modules/
.npm/
*.lnk

# ── Legacy ───────────────────────────────────────────────────
# Godot (legacy — migrated to UE5.7 on 2026-06-17)
# Unity
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Uu]ser[Ss]ettings/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
crashlytics-buildid.txt
sysinfo.txt

# ── Local Only ───────────────────────────────────────────────
.mcp.json
server.py
package-lock.json
package.json
scripts/

# ── OS Generated ─────────────────────────────────────────────
[Dd]esktop.ini
